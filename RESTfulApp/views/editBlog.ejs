<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create a Blog</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
</head>
<body>
<%- include('partials/navbar.ejs') %>
 <div class="container">
    <p class="h1">Edit the Article</p>
        <form action="/blog/<%= data.id%>?_method=PATCH", method="POST">
            <div class ="mb-3">
                <label for = "title" class="form-label" >Title</label>
                <input type = "text" id="title" name="title" class="form-control"  value= "<%=data.title %>">
            </div>
            <div class ="mb-3">
                <label for = "author" class="form-label">Author</label>
                <input type = "text" id = "author" name = "author" class="form-control" value=" <%=data.author %>">
            </div>
            <div  class ="mb-3">
                <label for = "article" class="form-label">Content </label>
                <textarea  id = "article" name = "article" placeholder = "Write here....." class="auto-resize form-control" rows="10"> <%=data.content %> </textarea>
            </div>
             <div class = "d-flex justify-content-betweend-flex justify-content-between">
                <input type = "submit" class="btn btn-success" value="Save">
                <a href = "/" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</body>
</html>


