<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
</head>
<body>
    <%- include('partials/navbar.ejs') %>
    <div class="container">
        <p class="h1"><%= data.title %> </p>
        <p class="h3 text-muted"><%=data.author %></p>
        <pre><%=data.content %> </pre>
    

        <div class = "d-flex justify-content-betweend-flex justify-content-between">
            <a href ='/blog/<%= data.id %> /edit' class="btn btn-warning">Edit</a>
            <form action='/blog/<%= data.id %> ?_method=DELETE' method = "POST" style="display:inline;"><input type = "submit" value="Delete"  class = "btn btn-danger"></form>
        </div>
    </div>
</body>
</html>